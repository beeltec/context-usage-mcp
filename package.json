{
  "name": "@beeltec/context-usage-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing get_context_usage, reporting the current session's raw token usage from its transcript/rollout. Supports Claude Code and OpenAI Codex CLI.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "context-usage-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "codex",
    "context-usage",
    "tokens"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beeltec/context-usage-mcp.git"
  },
  "homepage": "https://github.com/beeltec/context-usage-mcp#readme",
  "bugs": {
    "url": "https://github.com/beeltec/context-usage-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
